<component type="desktop-application">
    <id>org.nsh07.pomodoro</id>

    <name>Tomato</name>
    <summary>Minimalist, data-oriented pomodoro timer</summary>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-or-later</project_license>

    <developer id="org.nsh07">
        <name>Nishant Mishra</name>
    </developer>

    <description>
        <p>
            Tomato is a minimalist, data-oriented pomodoro timer that helps you stay
            focused and productive. Track your work sessions, breaks, and build
            healthy focus habits.
        </p>
    </description>

    <launchable type="desktop-id">org.nsh07.pomodoro.desktop</launchable>

    <url type="homepage">https://github.com/nsh07/Tomato</url>
    <url type="bugtracker">https://github.com/nsh07/Tomato/issues</url>
    <url type="vcs-browser">https://github.com/nsh07/Tomato</url>

    <content_rating type="oars-1.1" />

    <branding>
        <color scheme_preference="light" type="primary">#ff6347</color>
        <color scheme_preference="dark" type="primary">#c0392b</color>
    </branding>

    <supports>
        <control>pointing</control>
        <control>keyboard</control>
    </supports>

    <requires>
        <display_length compare="ge">360</display_length>
    </requires>

    <categories>
        <category>Utility</category>
    </categories>
</component>
