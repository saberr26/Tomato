<component type="desktop-application">
    <id>org.nsh07.pomodoro</id>

    <name>Tomato</name>
    <summary>Minimalist, data-oriented pomodoro timer</summary>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-or-later</project_license>

    <developer id="org.nsh07">
        <name>Nishant Mishra</name>
    </developer>

    <description>
        <p>Tomato is a minimalist Pomodoro timer based on Material 3 Expressive.</p>
        <p>
            Tomato is fully free and open-source, forever. You can find the source code and report
            bugs or suggest features on our GitHub repository.
        </p>
        <p>Features:</p>
        <ul>
            <li>Simple, minimalist UI based on the latest Material 3 Expressive guidelines</li>
            <li>Detailed statistics of work/study times in an easy-to-understand manner</li>
            <li>Stats for the current day visible at a glance</li>
            <li>Stats for the last week and last month shown in an easy-to-read, clean graph</li>
            <li>Additional stats for last week and month showing at what time of the day you're the
                most productive
            </li>
            <li>Customizable timer parameters</li>
            <li>Support for Android 16 Live Updates</li>
        </ul>
    </description>

    <launchable type="desktop-id">org.nsh07.pomodoro.desktop</launchable>

    <url type="homepage">https://github.com/nsh07/Tomato</url>
    <url type="bugtracker">https://github.com/nsh07/Tomato/issues</url>
    <url type="vcs-browser">https://github.com/nsh07/Tomato</url>
    <url type="donation">https://coff.ee/nsh07</url>
    <url type="contact">https://github.com/nsh07/Tomato/issues</url>
    <url type="translate">https://hosted.weblate.org/engage/tomato/</url>
    <url type="contribute">https://github.com/nsh07/Tomato</url>

    <content_rating type="oars-1.1" />

    <branding>
        <color scheme_preference="light" type="primary">#4C662B</color>
        <color scheme_preference="dark" type="primary">#B1D18A</color>
    </branding>

    <supports>
        <control>keyboard</control>
        <control>pointing</control>
        <control>touch</control>
    </supports>

    <requires>
        <display_length compare="ge">360</display_length>
    </requires>

    <categories>
        <category>Utility</category>
    </categories>

    <releases>
        <release date="2026-04-18" version="1.8.6-alpha01">
            <description>
                <p>Enhancements:</p>
                <ul>
                    <li>Translation updates (thanks to contributors on Weblate)</li>
                </ul>
                <p>
                    This release marks a milestone for Tomato: Tomato is now available on Desktop
                    (Linux, Mac and Windows). Try it out from the releases page on GitHub. It will
                    soon be available on Flathub and Snap Store for download on Linux as well.
                </p>
            </description>
        </release>
    </releases>
</component>
