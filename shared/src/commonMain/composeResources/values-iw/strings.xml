    <string name="total">סה״כ</string>
    <string name="backup_dialog_desc">הסטטיסטיקה וההגדרות שלך יישמרו בקובץ בתיקייה שבחרת. ניתן לשחזר את הנתונים האלה מאוחר יותר דרך %1$s.</string>
    <string name="restore_dialog_desc">הסטטיסטיקה וההגדרות שלך ישוחזרו מקובץ הגיבוי שבחרת. על היישום להיפתח מחדש בעת השלמת השחזור. <b>כל הנתונים הקיימים יימחקו, ולא יהיה ניתן להחזירם.</b></string>
    <string name="focus_history_calendar">תצוגת לוח שנה של היסטוריית המיקוד</string>
    <string name="focus_history_calendar_desc">היסטוריית המיקוד לחודש שעבר. ימי החודש שעבר מסומנים בצבע אחר. יש ללחוץ על תאריך מסוים למידע נוסף.</string>
    <string name="focus_history_heatmap_desc">היסטוריית המיקוד לשנה שעברה. צבעים עמוקים מסמלים משך זמן ארוך. הימים מאורגנים לפי חודשים. יש ללחוץ על יום למידע נוסף.</string>
    <string name="gap">הפרש</string>
    <string name="media_volume_for_alarm_desc">השמעה דרך האוזניות בלבד. אם האוזניות מנותקות, ההתראה תושמע דרך הרמקול ולפי עוצמת הקול של המדיה.</string>
